PORT=8080

# Default startup scan region (can be overridden from UI by Scan Current Area)
DEFAULT_BBOX_MIN_LAT=12.92
DEFAULT_BBOX_MIN_LON=77.63
DEFAULT_BBOX_MAX_LAT=12.94
DEFAULT_BBOX_MAX_LON=77.65

# Detection tuning
MAP_MATCH_MAX_DISTANCE_KM=0.05
WRONG_WAY_DELTA_ONEWAY_DEG=120
WRONG_WAY_DELTA_REVERSE_MAX_DEG=60
ANOMALY_STREAK_FOR_DANGER=3
CONE_LENGTH_KM=1.0
CONE_SPREAD_DEGREES=30
DANGER_CONE_UPDATE_INTERVAL_MS=250

# Simulation tuning
DEFAULT_SPECIFIC_PATH_VEHICLE_COUNT=8

# Overpass / OSM fetch tuning for large selected areas
OVERPASS_URL=https://overpass-api.de/api/interpreter
OVERPASS_URLS=https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter,https://overpass.openstreetmap.ru/api/interpreter
OVERPASS_TIMEOUT_MS=45000
OVERPASS_TILE_MAX_AREA_DEG2=0.0008
OVERPASS_TILE_MAX_RETRIES=2
OVERPASS_RETRY_BASE_DELAY_MS=600
OVERPASS_MAX_SPLIT_DEPTH=10
