# Example: http://localhost:8080
VITE_API_BASE_URL=http://localhost:8080

# Example: ws://localhost:8080
# If omitted, frontend derives this from VITE_API_BASE_URL
VITE_WS_URL=ws://localhost:8080

# Follow-cam / threat model tuning
VITE_THREAT_MAX_RANGE_M=1500
VITE_THREAT_MIN_CLOSING_SPEED_MPS=0.5
VITE_SIGNAL_STRONG_MAX_AGE_MS=1000
VITE_SIGNAL_MEDIUM_MAX_AGE_MS=3000
VITE_FOLLOW_CAM_ZOOM=17
VITE_FOLLOW_CAM_PITCH=50
VITE_STATS_POLL_MS=1000
VITE_TELEMETRY_FLUSH_MS=50
VITE_SAME_PATH_MAX_ROAD_DISTANCE_M=40
VITE_ALERT_PATH_LENGTH_M=800
VITE_ALERT_PATH_MAX_M=400
VITE_FEEDER_LOOKBACK_M=500
VITE_FEEDER_MAX_PATH_M=50
VITE_FEEDER_JUNCTION_MATCH_M=12
VITE_FEEDER_SEED_MAX_ALONG_M=140
VITE_DANGER_BRANCH_FIRST_NODE_MAX=1
VITE_DANGER_BRANCH_NEXT_NODE_MAX=1
VITE_DANGER_MIN_PATH_M=200
VITE_DANGER_MAX_INTERSECTIONS=3
VITE_DANGER_HIGHWAY_MAX_MULTIPLIER=1.8
VITE_DANGER_EXTEND_PAST_FIRST_INTERSECTION=false
VITE_DANGER_PULSE_PERIOD_MS=2400
VITE_MIN_GRAPH_EDGE_LENGTH_M=2
